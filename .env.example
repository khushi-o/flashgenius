# FlashGenius — copy to .env.local and fill in (never commit .env.local)

# --- Supabase (recommended) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server only; use only if strictly needed for privileged operations (prefer RLS-only).
SUPABASE_SERVICE_ROLE_KEY=

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Local dev quick login (npm run dev only; never set in production) ---
# Create this user in Supabase Dashboard → Authentication → Users (email + password).
# Authentication → Providers → Email: allow email/password sign-in for this test user.
# DEV_LOGIN_EMAIL=dev@yourmachine.local
# DEV_LOGIN_PASSWORD=choose-a-long-random-password

# --- LLM (server only; set keys for the provider you use) ---
# LLM_PROVIDER=gemini  (default)  |  groq
LLM_PROVIDER=gemini
GEMINI_API_KEY=
# Strongly recommended: use a 2.x Flash id (many keys 404 on gemini-1.5-flash / 1.5-pro).
# GEMINI_MODEL=gemini-2.5-flash-lite
# GEMINI_MODEL=gemini-2.0-flash
# GEMINI_MODEL=gemini-2.5-flash
# When LLM_PROVIDER=groq:
# GROQ_API_KEY=
# Optional Groq model id (default: llama-3.3-70b-versatile)
# GROQ_MODEL=llama-3.3-70b-versatile
# OPENAI_API_KEY=

# --- Optional: NextAuth (only if you add NextAuth on top of / instead of Supabase patterns) ---
# NEXTAUTH_URL=http://localhost:3000
# NEXTAUTH_SECRET=

# --- Optional: tune generation / uploads (unset = use code defaults) ---
# In-memory rate limit for POST /api/decks/[id]/generate (per user, per server instance).
# GENERATE_RATE_LIMIT_DISABLED=1
# GENERATE_RATE_LIMIT_MAX=30
# GENERATE_RATE_LIMIT_WINDOW_MINUTES=60
# Max source file upload size in MB (1–50; default in code is 10 if unset). Also set this on Vercel.
# On Vercel, the request body through a Serverless Function is still capped (~4.5 MB); larger files need direct-to-storage upload.
# MAX_UPLOAD_MB=20
# Set to 1 on Vercel temporarily to include `detail` in JSON for POST /api/decks/[id]/upload 500s (remove after debugging).
# UPLOAD_ROUTE_DEBUG=1
# MAX_CHUNKS_PER_DECK=15
# Max deck_chunks sent to the LLM per generate run (cost cap; default 15).
# GENERATION_MAX_CHUNKS=15
# MAX_CARDS_PER_DECK=40
# CHUNK_CHAR_TARGET=2000
# CHUNK_OVERLAP_CHARS=200
# Max pages stored in deck_pages per upload (book view).
# MAX_PDF_PAGES_STORED=30
# Truncate persisted chunk/page text (bytes-ish character cap).
# MAX_CHUNK_CONTENT_STORE_CHARS=8000
# MAX_PAGE_CONTENT_STORE_CHARS=6000
# Per-user soft cap: ready decks with cards touched since local midnight (omit or 0 = disabled).
# DAILY_GENERATION_LIMIT=3
# Space Gemini calls to reduce 429s (ms between requests).
# GEMINI_RATE_LIMIT_MS=4500
# GEMINI_MAX_RETRIES=2
# GENERATION_CHUNK_BUDGET_MS=4500
# DEDUPE_SIMILARITY_THRESHOLD=0.82
# DAILY_NEW_CARD_LIMIT=20
# Max cards returned for one GET /api/study/queue (session size).
# MAX_REVIEW_SESSION_SIZE=50
