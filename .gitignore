# ─── FlashGenius — never commit secrets or local-only state ───

# Markdown: README + architecture tracked; other *.md stay local
*.md
!README.md
!docs/ARCHITECTURE.md
!docs/PHASES.md
!docs/PLAN.md
!docs/SECURITY.md
!docs/COMPLETE_REFERENCE.md

# Environment and secrets (Tier A/B — see local docs/SECURITY.md)
.env
.env.*
!.env.example
.envrc
*.pem
*.key
*.pfx
*.p12
credentials.json
service-account*.json
*-credentials.json
.secrets/
secrets/

# Vercel (may link project and tokens locally)
.vercel

# Supabase CLI local state (can include connection strings / keys)
**/supabase/.branches
**/supabase/.temp

# Dependencies
node_modules/
.pnp
.pnp.js

# Next.js / build output
.next/
out/
build/
dist/

# Testing / coverage
coverage/
.nyc_output/

# Logs and debug
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# OS / editor (avoid accidental personal paths in commits)
.DS_Store
Thumbs.db
*.swp
*.swo
.idea/
*.sublime-*

# VS Code — keep optional shared settings only if you add *.example
.vscode/*
!.vscode/extensions.json

# Turbo / cache
.turbo

# TypeScript build info (local)
*.tsbuildinfo

# Optional: local SSL for dev
*.crt.local

# Optional: Sentry or other APM local config with DSN+auth
.sentryclirc
